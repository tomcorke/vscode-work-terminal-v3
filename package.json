{
  "name": "vscode-work-terminal-v3",
  "displayName": "Work Terminal",
  "description": "A VS Code port of work-terminal with a board-first workflow and per-item terminal sessions.",
  "version": "0.1.0",
  "publisher": "tomcorke",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "git@github.com:tomcorke/vscode-work-terminal-v3.git"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:workTerminal.focus",
    "onView:workTerminal.view"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workTerminal.focus",
        "title": "Work Terminal: Focus View"
      },
      {
        "command": "workTerminal.refreshView",
        "title": "Work Terminal: Refresh View"
      },
      {
        "command": "workTerminal.createWorkItem",
        "title": "Work Terminal: Create Work Item"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workTerminal",
          "title": "Work Terminal",
          "icon": "media/work-terminal-activity-bar.svg"
        }
      ]
    },
    "views": {
      "workTerminal": [
        {
          "id": "workTerminal.view",
          "name": "Board"
        }
      ]
    },
    "configuration": {
      "title": "Work Terminal",
      "properties": {
        "workTerminal.claudeCommand": {
          "type": "string",
          "default": "claude",
          "description": "Command used to launch Claude sessions."
        },
        "workTerminal.claudeExtraArgs": {
          "type": "string",
          "default": "",
          "description": "Extra arguments appended when launching Claude sessions."
        },
        "workTerminal.copilotCommand": {
          "type": "string",
          "default": "copilot",
          "description": "Command used to launch Copilot sessions."
        },
        "workTerminal.copilotExtraArgs": {
          "type": "string",
          "default": "",
          "description": "Extra arguments appended when launching Copilot sessions."
        }
      }
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "package": "pnpm run check && pnpm run build && pnpm exec vsce package",
    "vscode:prepublish": "pnpm run check && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.2",
    "eslint": "^8.57.1",
    "typescript": "^5.8.3",
    "vitest": "^3.0.9"
  }
}
